# ─────────────────────────────────────────────────────────────────────────────
# Meeting Analytics — environment configuration
# Copy this file to .env:  cp .env.example .env
# Defaults below match the Docker pgvector container exactly.
# No edits needed unless you changed credentials in docker-compose.yml.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL — Docker pgvector container
# Image:    pgvector/pgvector:pg17  (PostgreSQL 17 + pgvector extension)
# Port:     5434 (mapped from container's 5432)
# Database: rag_db
# Schema:   meeting_analytics  (created automatically by the load scripts)
DATABASE_URL=postgresql://rag_user:rag_pass@localhost:5434/rag_db

# Ollama — local LLM (used for cluster labeling during semantic_clustering.py)
# Start:  ollama serve
# Model:  ollama pull llama3.1:8b
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama

# Ollama — embeddings (768-dim, used to embed topic phrases for clustering)
# Model:  ollama pull nomic-embed-text:latest
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_DIMENSION=768
