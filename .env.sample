# PostgreSQL/Neon Configuration (pgvector)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
POSTGRES_TABLE_DOCUMENTS=documents
POSTGRES_TABLE_CHUNKS=chunks

# LLM Provider Configuration
# Options: openai, openrouter, ollama, gemini
# Available local models: llama3.1:8b, phi4:latest, llama3.2:3b
LLM_PROVIDER=ollama
LLM_API_KEY=ollama
# LLM_MODEL=llama3.1:8b
LLM_MODEL=llama3.2:3b
LLM_BASE_URL=http://localhost:11434/v1

# Embedding Provider Configuration
# Available local models: nomic-embed-text:latest (768 dimensions)
EMBEDDING_PROVIDER=ollama
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_DIMENSION=768

# Search Configuration
DEFAULT_MATCH_COUNT=10
MAX_MATCH_COUNT=50
DEFAULT_TEXT_WEIGHT=0.3

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO

# API Keys (replace with your own)
VOYAGE_API_KEY=your-voyage-api-key
OPENAI_API_KEY=your-openai-api-key
TAVILY_API_KEY=your-tavily-api-key
OPENAI_ADMIN_API_KEY=your-openai-admin-api-key

# Neo4j Configuration
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Neo4j Aura (cloud) - uncomment to use
#NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
#NEO4J_USERNAME=neo4j
#NEO4J_PASSWORD=your-aura-password
#NEO4J_DATABASE=neo4j
#AURA_INSTANCEID=your-instance-id
#AURA_INSTANCENAME=your-instance-name
